{
  "name": "ts-concur",
  "version": "0.2.1",
  "description": "Concurrent promise pool with adaptive concurrency, throttling and rate limiting for Node and browser",
  "keywords": [
    "adaptive",
    "concurrent",
    "pool",
    "promise",
    "rate-limit",
    "throttle",
    "workers"
  ],
  "license": "MIT",
  "author": "",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "release": "semantic-release",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "upgrade": "pnpm update --latest",
    "upgrade:check": "pnpm update --latest --dry-run",
    "taze": "taze --write --install"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@oxfmt/binding-darwin-arm64": "^0.40.0",
    "@oxlint/binding-darwin-arm64": "^1.55.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "taze": "^19.10.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "semantic-release": "^25.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
